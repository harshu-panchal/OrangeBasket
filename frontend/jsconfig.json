{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "checkJs": true,
        "strict": false,
        "noEmit": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@core/*": [
                "./src/core/*"
            ],
            "@shared/*": [
                "./src/shared/*"
            ],
            "@modules/*": [
                "./src/modules/*"
            ]
        }
    },
    "include": [
        "src"
    ]
}
